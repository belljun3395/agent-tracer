{
  "name": "agent-tracer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "lint:deps": "depcruise --config .dependency-cruiser.cjs packages",
    "depgraph": "depcruise --config .dependency-cruiser.cjs --output-type dot packages | dot -T svg -o docs/deps.svg",
    "test": "npm run test --workspaces --if-present",
    "publish:core": "npm publish --workspace @monitor/core --access public",
    "publish:server": "npm publish --workspace @monitor/server --access public",
    "publish:mcp": "npm publish --workspace @monitor/adapter-mcp --access public",
    "publish:web": "npm publish --workspace @monitor/web-app --access public",
    "publish:all": "npm run publish:core && npm run publish:server && npm run publish:mcp && npm run publish:web",
    "docs:dev": "vitepress dev docs --host 0.0.0.0 --port 5174",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs --host 0.0.0.0 --port 4174",
    "dev": "concurrently -k -n server,web \"npm run dev:server\" \"npm run dev:web\"",
    "dev:server": "NODE_OPTIONS=--conditions=development tsx watch --tsconfig packages/server/tsconfig.json packages/server/src/index.ts",
    "dev:web": "npm run dev --workspace @monitor/web-app -- --host 0.0.0.0",
    "seed": "NODE_OPTIONS=--conditions=development tsx packages/server/src/seed.ts",
    "start:server": "node packages/server/dist/index.js",
    "start:mcp": "node packages/adapter-mcp/dist/index.js",
    "setup:external": "node scripts/setup-external.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "concurrently": "^9.0.0",
    "dependency-cruiser": "^16.10.4",
    "eslint": "^9.0.0",
    "mermaid": "^11.13.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vitepress": "^2.0.0-alpha.17"
  }
}
