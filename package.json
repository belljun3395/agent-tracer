{
  "name": "agent-tracer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "lint:fix": "npm run lint:fix --workspaces --if-present",
    "lint:deps": "depcruise --config .dependency-cruiser.cjs packages",
    "test": "npm run test --workspaces --if-present",
    "docs:dev": "vitepress dev docs --host 0.0.0.0 --port 5174",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs --host 0.0.0.0 --port 4174",
    "dev": "concurrently -k -n server,web,analytics \"npm run dev:server\" \"npm run dev:web\" \"npm run dev --workspace @monitor/analytics\"",
    "dev:server": "AGENT_TRACER_ANALYTICS_ETL_INTERVAL_MS=60000 NODE_OPTIONS=--conditions=development tsx watch --tsconfig packages/server/tsconfig.dev.json packages/server/src/index.ts",
    "dev:web": "npm run dev --workspace @monitor/web -- --host 0.0.0.0",
    "seed": "NODE_OPTIONS=--conditions=development tsx --tsconfig tsconfig.dev.json packages/server/src/main/seed.ts",
    "start:server": "node packages/server/dist/index.js",
    "codex:observe": "npm --prefix packages/runtime run codex:observe --",
    "setup:external": "node scripts/setup-external.mjs",
    "setup:statusline": "bash scripts/install-statusline.sh",
    "publish:all": "npm publish --workspace @monitor/server --access public"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "concurrently": "^9.0.0",
    "dependency-cruiser": "^16.10.4",
    "eslint": "^9.0.0",
    "eslint-plugin-n": "^17.24.0",
    "globals": "^15.0.0",
    "mermaid": "^11.12.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vitepress": "^2.0.0-alpha.17"
  }
}
