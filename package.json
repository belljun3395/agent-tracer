{
  "name": "agent-tracer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "dev": "concurrently -k -n server,web \"npm run dev:server\" \"npm run dev:web\"",
    "dev:server": "NODE_OPTIONS=--conditions=development tsx watch packages/server/src/index.ts",
    "dev:web": "npm run dev --workspace @monitor/web -- --host 0.0.0.0",
    "seed": "NODE_OPTIONS=--conditions=development tsx packages/server/src/infrastructure/seed.ts",
    "start:server": "node packages/server/dist/index.js",
    "start:mcp": "node packages/mcp/dist/index.js"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "concurrently": "^9.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0"
  }
}
