{
  "name": "agent-tracer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/kernel",
    "packages/runtime",
    "packages/web",
    "packages/server/libs/*",
    "packages/server/apps/*"
  ],
  "scripts": {
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true",
    "build": "node scripts/run-workspaces.mjs build",
    "check:coauthors": "node scripts/check-coauthors.mjs",
    "test": "vitest run && node --test \"scripts/**/*.test.mjs\"",
    "lint:deps": "node scripts/check-dependencies.mjs",
    "gen:paths": "node scripts/gen-paths.mjs",
    "check:paths": "node scripts/gen-paths.mjs --check",
    "check:images": "node scripts/check-images.mjs",
    "lint": "npm run lint:format && npm run lint:types && npm run lint:structure",
    "lint:format": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:types": "node scripts/run-workspaces.mjs lint:types",
    "lint:structure": "node scripts/check-structure.mjs",
    "migration:generate": "NODE_OPTIONS=\"--import @swc-node/register/esm-register\" SWC_NODE_PROJECT=packages/server/libs/tracer-domain/tsconfig.json node node_modules/typeorm/cli.js migration:generate -d packages/server/libs/tracer-domain/src/persistence/tracer.datasource.ts",
    "migration:run": "NODE_OPTIONS=\"--import @swc-node/register/esm-register\" SWC_NODE_PROJECT=packages/server/libs/tracer-domain/tsconfig.json node node_modules/typeorm/cli.js migration:run -d packages/server/libs/tracer-domain/src/persistence/tracer.datasource.ts",
    "migration:generate:runtime": "NODE_OPTIONS=\"--import @swc-node/register/esm-register\" SWC_NODE_PROJECT=packages/server/apps/runtime-api/tsconfig.json node node_modules/typeorm/cli.js migration:generate -d packages/server/apps/runtime-api/src/runtime.datasource.ts",
    "migration:run:runtime": "NODE_OPTIONS=\"--import @swc-node/register/esm-register\" SWC_NODE_PROJECT=packages/server/apps/runtime-api/tsconfig.json node node_modules/typeorm/cli.js migration:run -d packages/server/apps/runtime-api/src/runtime.datasource.ts",
    "migrate:all": "npm run migration:run && npm run migration:run:runtime",
    "infra:up": "docker compose up -d runtime-db tracer-db redpanda redpanda-init opensearch connect connect-init temporal temporal-ui",
    "infra:down": "docker compose down",
    "stack:up": "node scripts/stack.mjs up",
    "stack:down": "node scripts/stack.mjs down",
    "stack:logs": "node scripts/stack.mjs logs",
    "dev": "npm run migrate:all && concurrently -k -n runtime-api,tracer-api,projector,web,ai-agent-worker,agents \"npm run dev:runtime-api\" \"npm run dev:tracer-api\" \"npm run dev:projector\" \"npm run dev:web\" \"npm run dev:ai-agent-worker\" \"npm run dev:agents\"",
    "dev:runtime-api": "NODE_OPTIONS=\"--conditions=development\" SWC_NODE_PROJECT=packages/server/apps/runtime-api/tsconfig.json node --watch scripts/dev-watch-entry.mjs @swc-node/register/esm-register packages/server/apps/runtime-api/src/main.ts",
    "dev:tracer-api": "NODE_OPTIONS=\"--conditions=development\" SWC_NODE_PROJECT=packages/server/apps/tracer-api/tsconfig.json node --watch scripts/dev-watch-entry.mjs @swc-node/register/esm-register packages/server/apps/tracer-api/src/main.ts",
    "dev:projector": "NODE_OPTIONS=\"--conditions=development\" SWC_NODE_PROJECT=packages/server/apps/projector/tsconfig.json node --watch scripts/dev-watch-entry.mjs @swc-node/register/esm-register packages/server/apps/projector/src/main.ts",
    "dev:ai-agent-worker": "NODE_OPTIONS=\"--conditions=development --import ./scripts/register-otel.mjs --import @swc-node/register/esm-register\" SWC_NODE_PROJECT=packages/server/apps/ai-agent-worker/tsconfig.json node packages/server/apps/ai-agent-worker/src/main.ts",
    "dev:web": "npm run dev --workspace @monitor/web -- --host 0.0.0.0",
    "dev:agents": "cd packages/agents && uv run python -m agent_graph",
    "setup:external": "node scripts/setup-external.mjs",
    "projection:rebuild": "NODE_OPTIONS=\"--import @swc-node/register/esm-register\" node scripts/rebuild-projection.mjs",
    "search:reindex": "NODE_OPTIONS=\"--conditions=development --import @swc-node/register/esm-register\" SWC_NODE_PROJECT=packages/server/apps/projector/tsconfig.json node packages/server/apps/projector/src/search.reindex.entry.ts",
    "e2e:failure": "NODE_OPTIONS=\"--import @swc-node/register/esm-register\" node scripts/e2e/failure-scenarios.mjs"
  },
  "engines": {
    "node": ">=24.0.0 <25.0.0"
  },
  "dependencies": {
    "@swc-node/register": "^1.11.1",
    "typescript": "^5.9.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "concurrently": "^9.0.0",
    "dependency-cruiser": "^16.10.4",
    "eslint": "^9.39.5",
    "globals": "^15.15.0",
    "typescript-eslint": "^8.63.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.7"
  }
}
