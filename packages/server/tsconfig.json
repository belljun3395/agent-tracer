{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "baseUrl": ".",
    "paths": {
      "~config/*": ["src/config/*"],
      "~adapters/*": ["src/adapters/*"],
      "~main/*": ["src/main/*"],
      "~work/*": ["src/work/*"],
      "~governance/*": ["src/governance/*"],
      "~identity/*": ["src/identity/*"],
      "@monitor/shared-kernel/*": ["../shared-kernel/src/*"],
      "@monitor/contracts/*": ["../contracts/src/*"],
      "@monitor/activity/*": ["../activity/src/*"]
    }
  },
  "include": ["src", "*.config.ts", "vitest.setup.ts"]
}
