{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "baseUrl": ".",
    "paths": {
      "~config/*": ["src/config/*"],
      "~domain/*": ["src/domain/*"],
      "~application/*": ["src/application/*"],
      "~adapters/*": ["src/adapters/*"],
      "~main/*": ["src/main/*"],
      "~session/*": ["src/session/*"]
    }
  },
  "include": ["src", "*.config.ts"]
}
