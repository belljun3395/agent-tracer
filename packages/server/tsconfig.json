{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "baseUrl": ".",
    "paths": {
      "~config/*": ["src/config/*"],
      "~adapters/*": ["src/adapters/*"],
      "~main/*": ["src/main/*"],
      "@monitor/shared/*": ["../shared/src/*"],
      "@monitor/activity/*": ["../activity/src/*"],
      "@monitor/work/*": ["../work/src/*"],
      "@monitor/governance/*": ["../governance/src/*"],
      "@monitor/identity/*": ["../identity/src/*"],
      "@monitor/ws-gateway/*": ["../ws-gateway/src/*"]
    }
  },
  "include": ["src", "*.config.ts", "vitest.setup.ts"]
}
