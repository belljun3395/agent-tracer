{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "baseUrl": ".",
    "paths": {
      "~config/*": ["src/config/*"],
      "~adapters/*": ["src/adapters/*"],
      "~main/*": ["src/main/*"],
      "~activity/*": ["src/activity/*"],
      "~work/*": ["src/work/*"],
      "~governance/*": ["src/governance/*"]
    }
  },
  "include": ["src", "*.config.ts"]
}
