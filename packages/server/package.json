{
  "name": "@monitor/server",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --external @monitor/core --external better-sqlite3 --external express --external ws --external zod",
    "lint": "eslint src",
    "test": "vitest run"
  },
  "dependencies": {
    "@monitor/core": "*",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-prometheus": "^0.57.0",
    "@opentelemetry/sdk-metrics": "^1.30.0",
    "better-sqlite3": "^12.0.0",
    "express": "^5.0.0",
    "ws": "^8.0.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.0.0",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.0",
    "tsup": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
