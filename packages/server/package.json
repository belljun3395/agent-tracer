{
  "name": "@monitor/server",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "development": "./src/server.entry.ts",
      "default": "./dist/index.js"
    },
    "./mcp": {
      "development": "./src/adapters/mcp/mcp.entry.ts",
      "default": "./dist/mcp.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "lint": "eslint . && npm run lint:types",
    "lint:fix": "eslint . --fix",
    "lint:types": "tsc -p tsconfig.test.json --noEmit",
    "start:mcp": "node ./dist/mcp.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.139",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@nestjs/common": "^11.1.18",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.18",
    "@nestjs/platform-express": "^11.1.18",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/typeorm": "^11.0.1",
    "@opensearch-project/opensearch": "^3.6.0",
    "express": "^5.0.0",
    "nestjs-zod": "^5.4.0",
    "node-notifier": "^10.0.1",
    "pg": "^8.22.0",
    "redis": "^5.12.1",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.28",
    "typeorm-transactional": "^0.5.0",
    "ws": "^8.0.0",
    "yaml": "^2.0.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.18",
    "@swc/core": "^1.15.30",
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "@types/node-notifier": "^8.0.5",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.0",
    "@types/ws": "^8.0.0",
    "supertest": "^7.0.0",
    "tsup": "^8.0.0",
    "unplugin-swc": "^1.5.9",
    "vitest": "^3.0.0"
  }
}
