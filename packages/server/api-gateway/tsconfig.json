{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "baseUrl": ".",
    "paths": {
      "~config/*": ["src/config/*"],
      "~adapters/*": ["src/adapters/*"],
      "~main/*": ["src/main/*"],
      "@monitor/shared/*": ["../shared/src/*"],
      "@monitor/timeline-api/*": ["../timeline-api/src/*"],
      "@monitor/run-api/*": ["../run-api/src/*"],
      "@monitor/rules-api/*": ["../rules-api/src/*"],
      "@monitor/insight-api/*": ["../insight-api/src/*"],
      "@monitor/identity-api/*": ["../identity-api/src/*"],
      "@monitor/ws-gateway/*": ["../ws-gateway/src/*"]
    }
  },
  "include": ["src", "*.config.ts", "vitest.setup.ts"]
}
