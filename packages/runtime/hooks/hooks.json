{
  "statusLine": {
    "type": "command",
    "command": "${CLAUDE_PLUGIN_ROOT}/bin/run-hook-claude.sh StatusLine"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/run-hook-claude.sh SessionStart"
          }
        ]
      }
    ],
    "Setup": [
      {
        "matcher": "init|maintenance",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/run-hook-claude.sh Setup"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/run-hook-claude.sh UserPromptSubmit"
          }
        ]
      }
    ],
    "UserPromptExpansion": [
      {
        "hooks": [
          {
            "type": "command",
            "async": true,
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/run-hook-claude.sh UserPromptExpansion"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/run-hook-claude.sh PreToolUse"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/run-hook-claude.sh PermissionRequest"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "async": true, "command": "${CLAUDE_PLUGIN_ROOT}/bin/run-hook-claude.sh PostToolUse/Bash" }
        ]
      },
      {
        "matcher": "PowerShell",
        "hooks": [
          { "type": "command", "async": true, "command": "${CLAUDE_PLUGIN_ROOT}/bin/run-hook-claude.sh PostToolUse/PowerShell" }
        ]
      },
      {
        "matcher": "BashOutput",
        "hooks": [
          { "type": "command", "async": true, "command": "${CLAUDE_PLUGIN_ROOT}/bin/run-hook-claude.sh PostToolUse/BashOutput" }
        ]
      },
      {
        "matcher": "KillShell",
        "hooks": [
          { "type": "command", "async": true, "command": "${CLAUDE_PLUGIN_ROOT}/bin/run-hook-claude.sh PostToolUse/KillShell" }
        ]
      },
      {
        "matcher": "Monitor",
        "hooks": [
          { "type": "command", "async": true, "command": "${CLAUDE_PLUGIN_ROOT}/bin/run-hook-claude.sh PostToolUse/Monitor" }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          { "type": "command", "async": true, "command": "${CLAUDE_PLUGIN_ROOT}/bin/run-hook-claude.sh PostToolUse/Edit" }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          { "type": "command", "async": true, "command": "${CLAUDE_PLUGIN_ROOT}/bin/run-hook-claude.sh PostToolUse/Write" }
        ]
      },
      {
        "matcher": "NotebookEdit",
        "hooks": [
          { "type": "command", "async": true, "command": "${CLAUDE_PLUGIN_ROOT}/bin/run-hook-claude.sh PostToolUse/NotebookEdit" }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          { "type": "command", "async": true, "command": "${CLAUDE_PLUGIN_ROOT}/bin/run-hook-claude.sh PostToolUse/Read" }
        ]
      },
      {
        "matcher": "Glob",
        "hooks": [
          { "type": "command", "async": true, "command": "${CLAUDE_PLUGIN_ROOT}/bin/run-hook-claude.sh PostToolUse/Glob" }
        ]
      },
      {
        "matcher": "Grep",
        "hooks": [
          { "type": "command", "async": true, "command": "${CLAUDE_PLUGIN_ROOT}/bin/run-hook-claude.sh PostToolUse/Grep" }
        ]
      },
      {
        "matcher": "LSP",
        "hooks": [
          { "type": "command", "async": true, "command": "${CLAUDE_PLUGIN_ROOT}/bin/run-hook-claude.sh PostToolUse/LSP" }
        ]
      },
      {
        "matcher": "WebFetch",
        "hooks": [
          { "type": "command", "async": true, "command": "${CLAUDE_PLUGIN_ROOT}/bin/run-hook-claude.sh PostToolUse/WebFetch" }
        ]
      },
      {
        "matcher": "WebSearch",
        "hooks": [
          { "type": "command", "async": true, "command": "${CLAUDE_PLUGIN_ROOT}/bin/run-hook-claude.sh PostToolUse/WebSearch" }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          { "type": "command", "async": true, "command": "${CLAUDE_PLUGIN_ROOT}/bin/run-hook-claude.sh PostToolUse/Agent" }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          { "type": "command", "async": true, "command": "${CLAUDE_PLUGIN_ROOT}/bin/run-hook-claude.sh PostToolUse/Skill" }
        ]
      },
      {
        "matcher": "TaskCreate",
        "hooks": [
          { "type": "command", "async": true, "command": "${CLAUDE_PLUGIN_ROOT}/bin/run-hook-claude.sh PostToolUse/TaskCreate" }
        ]
      },
      {
        "matcher": "TaskUpdate",
        "hooks": [
          { "type": "command", "async": true, "command": "${CLAUDE_PLUGIN_ROOT}/bin/run-hook-claude.sh PostToolUse/TaskUpdate" }
        ]
      },
      {
        "matcher": "TodoWrite",
        "hooks": [
          { "type": "command", "async": true, "command": "${CLAUDE_PLUGIN_ROOT}/bin/run-hook-claude.sh PostToolUse/TodoWrite" }
        ]
      },
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          { "type": "command", "async": true, "command": "${CLAUDE_PLUGIN_ROOT}/bin/run-hook-claude.sh PostToolUse/AskUserQuestion" }
        ]
      },
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          { "type": "command", "async": true, "command": "${CLAUDE_PLUGIN_ROOT}/bin/run-hook-claude.sh PostToolUse/ExitPlanMode" }
        ]
      },
      {
        "matcher": "EnterPlanMode|EnterWorktree|ExitWorktree",
        "hooks": [
          { "type": "command", "async": true, "command": "${CLAUDE_PLUGIN_ROOT}/bin/run-hook-claude.sh PostToolUse/ModeChange" }
        ]
      },
      {
        "matcher": "CronCreate|CronDelete|CronList",
        "hooks": [
          { "type": "command", "async": true, "command": "${CLAUDE_PLUGIN_ROOT}/bin/run-hook-claude.sh PostToolUse/Cron" }
        ]
      },
      {
        "matcher": "ToolSearch",
        "hooks": [
          { "type": "command", "async": true, "command": "${CLAUDE_PLUGIN_ROOT}/bin/run-hook-claude.sh PostToolUse/ToolSearch" }
        ]
      },
      {
        "matcher": "mcp__.*",
        "hooks": [
          { "type": "command", "async": true, "command": "${CLAUDE_PLUGIN_ROOT}/bin/run-hook-claude.sh PostToolUse/Mcp" }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Bash|PowerShell|BashOutput|KillShell|Monitor|Edit|Write|NotebookEdit|Read|Glob|Grep|LSP|WebFetch|WebSearch|Agent|Skill|TaskCreate|TaskUpdate|TodoWrite|AskUserQuestion|ExitPlanMode|EnterPlanMode|EnterWorktree|ExitWorktree|CronCreate|CronDelete|CronList|ToolSearch|mcp__.*",
        "hooks": [
          { "type": "command", "async": true, "command": "${CLAUDE_PLUGIN_ROOT}/bin/run-hook-claude.sh PostToolUseFailure" }
        ]
      }
    ],
    "PostToolBatch": [
      {
        "hooks": [
          { "type": "command", "async": true, "command": "${CLAUDE_PLUGIN_ROOT}/bin/run-hook-claude.sh PostToolBatch" }
        ]
      }
    ],
    "PermissionDenied": [
      {
        "matcher": "Bash|PowerShell|Edit|Write|NotebookEdit|Read|Glob|Grep|LSP|WebFetch|WebSearch|Agent|Skill|Monitor|TaskCreate|TaskUpdate|TodoWrite|AskUserQuestion|ExitPlanMode|EnterPlanMode|EnterWorktree|ExitWorktree|CronCreate|CronDelete|CronList|ToolSearch|mcp__.*",
        "hooks": [
          { "type": "command", "async": true, "command": "${CLAUDE_PLUGIN_ROOT}/bin/run-hook-claude.sh PermissionDenied" }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "hooks": [
          { "type": "command", "async": true, "command": "${CLAUDE_PLUGIN_ROOT}/bin/run-hook-claude.sh InstructionsLoaded" }
        ]
      }
    ],
    "ConfigChange": [
      {
        "hooks": [
          { "type": "command", "async": true, "command": "${CLAUDE_PLUGIN_ROOT}/bin/run-hook-claude.sh ConfigChange" }
        ]
      }
    ],
    "CwdChanged": [
      {
        "hooks": [
          { "type": "command", "async": true, "command": "${CLAUDE_PLUGIN_ROOT}/bin/run-hook-claude.sh CwdChanged" }
        ]
      }
    ],
    "FileChanged": [
      {
        "matcher": "CLAUDE.md|.env|.envrc|.claude/settings.json|.claude/settings.local.json",
        "hooks": [
          { "type": "command", "async": true, "command": "${CLAUDE_PLUGIN_ROOT}/bin/run-hook-claude.sh FileChanged" }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/bin/run-hook-claude.sh WorktreeCreate" }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          { "type": "command", "async": true, "command": "${CLAUDE_PLUGIN_ROOT}/bin/run-hook-claude.sh WorktreeRemove" }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          { "type": "command", "async": true, "command": "${CLAUDE_PLUGIN_ROOT}/bin/run-hook-claude.sh Notification" }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          { "type": "command", "async": true, "command": "${CLAUDE_PLUGIN_ROOT}/bin/run-hook-claude.sh PreCompact" }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          { "type": "command", "async": true, "command": "${CLAUDE_PLUGIN_ROOT}/bin/run-hook-claude.sh PostCompact" }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/bin/run-hook-claude.sh SubagentStart" }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          { "type": "command", "async": true, "command": "${CLAUDE_PLUGIN_ROOT}/bin/run-hook-claude.sh SubagentStop" }
        ]
      }
    ],
    "TaskCreated": [
      {
        "hooks": [
          { "type": "command", "async": true, "command": "${CLAUDE_PLUGIN_ROOT}/bin/run-hook-claude.sh TaskCreated" }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          { "type": "command", "async": true, "command": "${CLAUDE_PLUGIN_ROOT}/bin/run-hook-claude.sh TaskCompleted" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "async": true, "command": "${CLAUDE_PLUGIN_ROOT}/bin/run-hook-claude.sh Stop" }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          { "type": "command", "async": true, "command": "${CLAUDE_PLUGIN_ROOT}/bin/run-hook-claude.sh StopFailure" }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          { "type": "command", "async": true, "command": "${CLAUDE_PLUGIN_ROOT}/bin/run-hook-claude.sh SessionEnd" }
        ]
      }
    ]
  }
}
