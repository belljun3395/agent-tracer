{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "types": ["vite/client", "react"],
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "~domain/*": ["src/domain/*"],
      "~io/*": ["src/io/*"],
      "~state/*": ["src/state/*"],
      "~app/*": ["src/app/*"],
      "~config/*": ["src/config/*"],
      "~ui/*": ["src/ui/*"],
      "~lib/*": ["src/lib/*"],
      "~features/*": ["src/features/*"]
    }
  },
  "include": ["src", "*.config.ts"]
}
