FROM node:22-slim AS builder

WORKDIR /app
COPY package*.json ./
COPY packages/server/package.json packages/server/
COPY packages/adapter-mcp/package.json packages/adapter-mcp/
COPY packages/web-app/package.json packages/web-app/

# Optional: Install build tools if native modules like better-sqlite3 need them
RUN apt-get update && apt-get install -y python3 make g++ && rm -rf /var/lib/apt/lists/*
RUN npm ci

COPY . .
RUN npm run build --workspace=@monitor/server --workspace=@monitor/adapter-mcp

FROM node:22-slim

WORKDIR /app
COPY --from=builder /app/package*.json ./
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/packages ./packages

WORKDIR /app
ENV NODE_ENV=production

EXPOSE 3847
CMD ["npm", "run", "start:server"]
