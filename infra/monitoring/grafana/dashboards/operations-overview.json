{
  "title": "Operations Overview",
  "uid": "operations-overview",
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "refresh": "10s",
  "tags": ["agent-tracer", "operations", "overview"],
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "links": [
    {
      "asDropdown": false,
      "icon": "dashboard",
      "includeVars": true,
      "keepTime": true,
      "targetBlank": false,
      "title": "Service RED & Dependencies",
      "type": "link",
      "url": "/d/service-red-dependencies"
    },
    {
      "asDropdown": false,
      "icon": "dashboard",
      "includeVars": false,
      "keepTime": true,
      "targetBlank": false,
      "title": "Event Pipeline",
      "type": "link",
      "url": "/d/event-pipeline"
    },
    {
      "asDropdown": false,
      "icon": "dashboard",
      "includeVars": false,
      "keepTime": true,
      "targetBlank": false,
      "title": "AI Job Observability",
      "type": "link",
      "url": "/d/ai-job-observability"
    },
    {
      "asDropdown": false,
      "icon": "dashboard",
      "includeVars": false,
      "keepTime": true,
      "targetBlank": false,
      "title": "Platform Health",
      "type": "link",
      "url": "/d/platform-health"
    }
  ],
  "templating": {
    "list": [
      {
        "allValue": ".*",
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "definition": "label_values(http_server_duration_count, service)",
        "hide": 0,
        "includeAll": true,
        "label": "Application service",
        "multi": true,
        "name": "service",
        "options": [],
        "query": {
          "query": "label_values(http_server_duration_count, service)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      },
      {
        "allValue": ".+",
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "definition": "label_values(service_name)",
        "hide": 0,
        "includeAll": true,
        "label": "Service",
        "multi": true,
        "name": "service_name",
        "options": [],
        "query": "label_values(service_name)",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      },
      {
        "allValue": ".*",
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "hide": 0,
        "includeAll": true,
        "label": "Detected level",
        "multi": true,
        "name": "detected_level",
        "options": [],
        "query": "trace,debug,info,warn,error,critical,fatal,unknown",
        "skipUrlSync": false,
        "type": "custom"
      },
      {
        "allValue": ".*",
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "definition": "label_values({service_name=~\"$service_name\"}, stream)",
        "hide": 0,
        "includeAll": true,
        "label": "Stream",
        "multi": true,
        "name": "stream",
        "options": [],
        "query": "label_values({service_name=~\"$service_name\"}, stream)",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      },
      {
        "current": {
          "selected": true,
          "text": "",
          "value": ""
        },
        "hide": 0,
        "label": "Contains text",
        "name": "search",
        "options": [
          {
            "selected": true,
            "text": "",
            "value": ""
          }
        ],
        "query": "",
        "skipUrlSync": false,
        "type": "textbox"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Immediate operating signals",
      "type": "row",
      "description": "알림, scrape 상태, HTTP 오류율, 이벤트 투영 갭을 한눈에 확인한다.",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0}
    },
    {
      "id": 2,
      "title": "Firing alerts",
      "type": "stat",
      "description": "현재 firing 상태인 Prometheus 알림 수. 0이 아니면 아래 알림 패널에서 원인을 확인한다.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum(ALERTS{alertstate=\"firing\"}) or vector(0)",
          "instant": true,
          "legendFormat": "firing",
          "range": false,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 1}
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "showPercentChange": false,
        "textMode": "auto",
        "wideLayout": true
      },
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 1}
    },
    {
      "id": 3,
      "title": "Down scrape targets",
      "type": "stat",
      "description": "Prometheus가 scrape하지 못하는 대상 수. 인프라 또는 애플리케이션 관측 공백을 뜻한다.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "editorMode": "code",
          "expr": "count(up == 0) or vector(0)",
          "instant": true,
          "legendFormat": "down",
          "range": false,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 1}
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "showPercentChange": false,
        "textMode": "auto",
        "wideLayout": true
      },
      "gridPos": {"h": 5, "w": 6, "x": 6, "y": 1}
    },
    {
      "id": 4,
      "title": "HTTP 5xx ratio",
      "type": "stat",
      "description": "선택한 애플리케이션 서비스의 최근 구간 5xx 요청 비율. 5% 이상을 장애 기준으로 본다.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "editorMode": "code",
          "expr": "(sum(rate(http_server_duration_count{service=~\"$service\",http_status_code=~\"5..\"}[$__rate_interval])) / clamp_min(sum(rate(http_server_duration_count{service=~\"$service\"}[$__rate_interval])), 0.000001)) or vector(0)",
          "instant": true,
          "legendFormat": "5xx ratio",
          "range": false,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "decimals": 2,
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.01},
              {"color": "red", "value": 0.05}
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "showPercentChange": false,
        "textMode": "auto",
        "wideLayout": true
      },
      "gridPos": {"h": 5, "w": 6, "x": 12, "y": 1}
    },
    {
      "id": 5,
      "title": "Active AI jobs",
      "type": "stat",
      "description": "현재 pending 또는 running 상태인 AI 잡 수. 0은 정상 idle이며 증가가 지속되면 AI Job 대시보드에서 backend와 oldest age를 확인한다.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum(ai_jobs_status_count) or vector(0)",
          "instant": true,
          "legendFormat": "active jobs",
          "range": false,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 5}
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "showPercentChange": false,
        "textMode": "auto",
        "wideLayout": true
      },
      "gridPos": {"h": 5, "w": 6, "x": 18, "y": 1}
    },
    {
      "id": 6,
      "title": "Application RED",
      "type": "row",
      "description": "HTTP 요청량, 지연, 오류 비율을 서비스별로 비교한다.",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 6}
    },
    {
      "id": 7,
      "title": "HTTP request rate",
      "type": "timeseries",
      "description": "선택한 서비스가 처리한 HTTP 요청 초당 건수.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (service) (rate(http_server_duration_count{service=~\"$service\"}[$__rate_interval]))",
          "instant": false,
          "legendFormat": "{{service}}",
          "range": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 12, "lineInterpolation": "linear", "lineWidth": 2, "showPoints": "never", "spanNulls": false, "stacking": {"group": "A", "mode": "none"}},
          "min": 0,
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]},
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {"legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"hideZeros": false, "mode": "multi", "sort": "desc"}},
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 7}
    },
    {
      "id": 8,
      "title": "HTTP latency p95",
      "type": "timeseries",
      "description": "구 stable HTTP semconv histogram의 p95 지연. 이 저장소의 http_server_duration 단위는 밀리초다.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (le, service) (rate(http_server_duration_bucket{service=~\"$service\"}[$__rate_interval])))",
          "instant": false,
          "legendFormat": "{{service}} p95",
          "range": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10, "lineInterpolation": "linear", "lineWidth": 2, "showPoints": "never", "spanNulls": false, "stacking": {"group": "A", "mode": "none"}},
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 500},
              {"color": "red", "value": 1000}
            ]
          },
          "unit": "ms"
        },
        "overrides": []
      },
      "options": {"legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"hideZeros": false, "mode": "multi", "sort": "desc"}},
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 7}
    },
    {
      "id": 9,
      "title": "HTTP 5xx ratio by service",
      "type": "timeseries",
      "description": "서비스별 전체 요청 중 5xx 응답 비율. 트래픽이 없는 구간은 표시하지 않는다.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (service) (rate(http_server_duration_count{service=~\"$service\",http_status_code=~\"5..\"}[$__rate_interval])) / clamp_min(sum by (service) (rate(http_server_duration_count{service=~\"$service\"}[$__rate_interval])), 0.000001)",
          "instant": false,
          "legendFormat": "{{service}}",
          "range": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 18, "lineInterpolation": "linear", "lineWidth": 2, "showPoints": "never", "spanNulls": false, "stacking": {"group": "A", "mode": "none"}},
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.01},
              {"color": "red", "value": 0.05}
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "options": {"legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"hideZeros": false, "mode": "multi", "sort": "desc"}},
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 7}
    },
    {
      "id": 10,
      "title": "Availability and alerts",
      "type": "row",
      "description": "현재 scrape 상태와 활성 알림의 구체적인 대상을 확인한다.",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 15}
    },
    {
      "id": 11,
      "title": "Active alerts",
      "type": "table",
      "description": "현재 firing 중인 알림과 severity, 대상 라벨을 표시한다.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "editorMode": "code",
          "expr": "ALERTS{alertstate=\"firing\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "{{alertname}} / {{severity}}",
          "range": false,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "custom": {"align": "auto", "cellOptions": {"type": "auto"}, "inspect": false},
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}]},
          "unit": "short"
        },
        "overrides": []
      },
      "options": {"cellHeight": "sm", "footer": {"countRows": false, "fields": "", "reducer": ["sum"], "show": false}, "showHeader": true, "sortBy": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16}
    },
    {
      "id": 12,
      "title": "Scrape target health",
      "type": "bargauge",
      "description": "핵심 애플리케이션·관측 서비스의 Prometheus scrape 상태. 1은 정상, 0은 수집 실패다.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "editorMode": "code",
          "expr": "up{job=~\"app-services|otel-collector|otlp-app-metrics|temporal-sdk|tempo|loki|alertmanager|prometheus\"}",
          "instant": true,
          "legendFormat": "{{job}} / {{instance}}",
          "range": false,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "decimals": 0,
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "green", "value": 1}
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {"displayMode": "gradient", "legend": {"calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": false}, "maxVizHeight": 300, "minVizHeight": 16, "minVizWidth": 8, "namePlacement": "auto", "orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "showUnfilled": true, "sizing": "auto", "text": {}, "valueMode": "color"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16}
    },
    {
      "id": 13,
      "title": "Pipeline, AI jobs, and logs",
      "type": "row",
      "description": "이벤트 처리 신선도, AI 잡 실패, 서비스 로그 오류량을 함께 비교한다.",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 24}
    },
    {
      "id": 14,
      "title": "Projection gap by consumer",
      "type": "timeseries",
      "description": "consumer별 runtime 원장 seq와 적용 seq 차이. 증가 추세는 처리 정체 또는 sink 장애 신호다.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "editorMode": "code",
          "expr": "clamp_min(scalar(runtime_ledger_max_seq) - pipeline_applied_seq, 0)",
          "instant": false,
          "legendFormat": "{{consumer}}",
          "range": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 15, "lineInterpolation": "linear", "lineWidth": 2, "showPoints": "never", "spanNulls": false, "stacking": {"group": "A", "mode": "none"}},
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 100},
              {"color": "red", "value": 1000}
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {"legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"hideZeros": false, "mode": "multi", "sort": "desc"}},
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 25}
    },
    {
      "id": 15,
      "title": "AI job failure rate",
      "type": "timeseries",
      "description": "job kind별 error_type이 기록된 에이전트 invocation 초당 건수.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (agent_tracer_job_kind) (rate(gen_ai_invoke_agent_duration_count{error_type=~\".+\"}[$__rate_interval]))",
          "instant": false,
          "legendFormat": "{{agent_tracer_job_kind}}",
          "range": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "bars", "fillOpacity": 55, "lineInterpolation": "linear", "lineWidth": 1, "showPoints": "never", "spanNulls": false, "stacking": {"group": "A", "mode": "normal"}},
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 0.001}
            ]
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {"legend": {"calcs": ["sum"], "displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"hideZeros": false, "mode": "multi", "sort": "desc"}},
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 25}
    },
    {
      "id": 16,
      "title": "Error log rate by service",
      "type": "timeseries",
      "description": "Loki가 error/critical/fatal로 판별한 서비스별 로그 초당 건수. 운영 홈은 민감한 사용자·assistant 본문을 노출하지 않고 집계만 표시한다.",
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (service_name) (rate({service_name=~\".+\", detected_level=~\"error|critical|fatal\"}[$__auto]))",
          "legendFormat": "{{service_name}}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "bars", "fillOpacity": 55, "lineInterpolation": "linear", "lineWidth": 1, "showPoints": "never", "spanNulls": false, "stacking": {"group": "A", "mode": "normal"}},
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 0.001}
            ]
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {"legend": {"calcs": ["sum"], "displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"hideZeros": false, "mode": "multi", "sort": "desc"}},
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 25}
    },
    {
      "id": 17,
