    {
      "id": 7,
      "title": "Trace span RED",
      "type": "row",
      "description": "Tempo metrics-generator가 만든 traces_spanmetrics_*를 사용해 HTTP 밖의 runtime, agent, tool, database span을 함께 본다.",
      "gridPos": {
