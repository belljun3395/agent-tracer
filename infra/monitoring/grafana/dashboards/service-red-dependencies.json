  "panels": [
    {
      "id": 1,
      "title": "HTTP server RED",
      "type": "row",
      "description": "실제 http_server_duration_* histogram의 service, http_route, http_method, http_status_code 라벨로 요청량·오류·지연을 분석한다.",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "id": 2,
      "title": "Request rate by route",
      "type": "timeseries",
      "description": "선택한 서비스·route·method 조합의 HTTP 요청 초당 건수.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (service, http_method, http_route) (rate(http_server_duration_count{service=~\"$app_service\",http_route=~\"$route\",http_method=~\"$method\"}[$__rate_interval]))",
          "instant": false,
          "legendFormat": "{{service}} {{http_method}} {{http_route}}",
          "range": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 12,
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": {
              "group": "A",
              "mode": "none"
            }
          },
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "hideZeros": false,
          "mode": "multi",
          "sort": "desc"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 1
      }
    },
    {
      "id": 3,
      "title": "HTTP 5xx ratio by service",
      "type": "timeseries",
      "description": "서비스별 5xx / 전체 요청 비율. 5% 이상이면 critical 기준이다.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (service) (rate(http_server_duration_count{service=~\"$app_service\",http_route=~\"$route\",http_method=~\"$method\",http_status_code=~\"5..\"}[$__rate_interval])) / clamp_min(sum by (service) (rate(http_server_duration_count{service=~\"$app_service\",http_route=~\"$route\",http_method=~\"$method\"}[$__rate_interval])), 0.000001)",
          "instant": false,
          "legendFormat": "{{service}}",
          "range": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 18,
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": {
              "group": "A",
              "mode": "none"
            }
          },
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.01
              },
              {
                "color": "red",
                "value": 0.05
              }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "hideZeros": false,
          "mode": "multi",
          "sort": "desc"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 1
      }
    },
    {
      "id": 4,
      "title": "HTTP latency quantiles",
      "type": "timeseries",
      "description": "선택 범위 전체의 p50/p95/p99 서버 지연. http_server_duration histogram은 밀리초 단위다.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "histogram_quantile(0.50, sum by (le, service) (rate(http_server_duration_bucket{service=~\"$app_service\",http_route=~\"$route\",http_method=~\"$method\"}[$__rate_interval])))",
          "instant": false,
          "legendFormat": "{{service}} p50",
          "range": true,
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (le, service) (rate(http_server_duration_bucket{service=~\"$app_service\",http_route=~\"$route\",http_method=~\"$method\"}[$__rate_interval])))",
          "instant": false,
          "legendFormat": "{{service}} p95",
          "range": true,
          "refId": "B"
        },
        {
          "editorMode": "code",
          "expr": "histogram_quantile(0.99, sum by (le, service) (rate(http_server_duration_bucket{service=~\"$app_service\",http_route=~\"$route\",http_method=~\"$method\"}[$__rate_interval])))",
          "instant": false,
          "legendFormat": "{{service}} p99",
          "range": true,
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 8,
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": {
              "group": "A",
              "mode": "none"
            }
          },
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 500
              },
              {
                "color": "red",
                "value": 1000
              }
            ]
          },
          "unit": "ms"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "hideZeros": false,
          "mode": "multi",
          "sort": "desc"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 9
      }
    },
    {
      "id": 5,
      "title": "HTTP status rate",
      "type": "timeseries",
      "description": "응답 status code별 요청률. 4xx는 호출자 문제, 5xx는 서비스 문제의 시작점으로 본다.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (http_status_code) (rate(http_server_duration_count{service=~\"$app_service\",http_route=~\"$route\",http_method=~\"$method\"}[$__rate_interval]))",
          "instant": false,
          "legendFormat": "HTTP {{http_status_code}}",
          "range": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 60,
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": {
              "group": "A",
              "mode": "normal"
            }
          },
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": [
            "sum"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "hideZeros": false,
          "mode": "multi",
          "sort": "desc"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 9
      }
    },
    {
      "id": 6,
      "title": "Slowest HTTP routes (p95)",
      "type": "bargauge",
      "description": "현재 시점의 p95 기준 가장 느린 route 10개. 요청량이 극히 적은 route는 별도 확인이 필요하다.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "topk(10, histogram_quantile(0.95, sum by (le, service, http_method, http_route) (rate(http_server_duration_bucket{service=~\"$app_service\",http_route=~\"$route\",http_method=~\"$method\"}[$__rate_interval]))))",
          "instant": true,
          "legendFormat": "{{service}} {{http_method}} {{http_route}}",
          "range": false,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 500
              },
              {
                "color": "red",
                "value": 1000
              }
            ]
          },
          "unit": "ms"
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": false
