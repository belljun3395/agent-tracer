      "title": "Infrastructure resources (USE)",
      "type": "row"
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Active connections",
      "description": "Shows active Postgres backend connections per database; sustained growth toward max_connections signals connection-pool exhaustion risk.",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 0,
        "y": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (database) (pg_stat_database_numbackends)",
          "legendFormat": "{{database}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Transactions/sec (commit + rollback)",
      "description": "Shows Postgres commit+rollback throughput per database; a sudden drop with unchanged traffic indicates the database is stalled or unreachable.",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 8,
        "y": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (database) (rate(pg_stat_database_xact_commit[1m]) + rate(pg_stat_database_xact_rollback[1m]))",
          "legendFormat": "{{database}}"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Cache hit ratio",
      "description": "Shows the Postgres buffer cache hit ratio per database; a sustained drop below roughly 99% means queries are increasingly hitting disk and read latency will rise.",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 16,
        "y": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (database) (rate(pg_stat_database_blks_hit[5m])) / (sum by (database) (rate(pg_stat_database_blks_hit[5m])) + sum by (database) (rate(pg_stat_database_blks_read[5m])))",
          "legendFormat": "{{database}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        },
        "overrides": []
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Redpanda disk free",
      "description": "Shows remaining disk space on Redpanda brokers; approaching zero risks the broker refusing writes and blocking the ingest pipeline.",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 0,
        "y": 14
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "redpanda_storage_disk_free_bytes",
          "legendFormat": "free"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "OpenSearch JVM heap usage",
      "description": "Shows OpenSearch JVM heap utilization; sustained values above roughly 85% risk long GC pauses and node instability.",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 8,
        "y": 14
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "elasticsearch_jvm_memory_used_bytes{area=\"heap\"} / elasticsearch_jvm_memory_max_bytes{area=\"heap\"}",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        },
        "overrides": []
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "OpenSearch indexing/search rate",
      "description": "Shows OpenSearch indexing and search request throughput; an unexpected rate collapse indicates the ingest or query path is broken upstream.",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 16,
        "y": 14
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "rate(elasticsearch_indices_indexing_index_total[1m])",
          "legendFormat": "index"
        },
        {
          "expr": "rate(elasticsearch_indices_search_query_total[1m])",
          "legendFormat": "search"
        }
      ]
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Event loop utilization",
      "description": "Shows Node.js event loop utilization per service; sustained values near 100% mean the process is CPU-bound and can no longer process requests promptly.",
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 21
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "nodejs_eventloop_utilization",
          "legendFormat": "{{service}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        },
        "overrides": []
      }
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "V8 heap used (all spaces)",
      "description": "Shows V8 heap memory used per Node.js service; steady unbounded growth indicates a memory leak heading toward an OOM crash.",
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 12,
        "y": 21
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (service) (v8js_memory_heap_used)",
          "legendFormat": "{{service}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      }
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Process CPU utilization",
      "description": "Shows CPU utilization per agents process; sustained saturation means agent jobs will queue and slow down.",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 0,
        "y": 28
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (exported_job) (process_cpu_utilization)",
          "legendFormat": "{{exported_job}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        },
        "overrides": []
      }
    },
    {
      "id": 16,
      "type": "timeseries",
      "title": "Process resident memory",
      "description": "Shows resident memory per agents process; continuous growth without leveling off signals a leak that will eventually trigger an OOM kill.",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 8,
        "y": 28
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (exported_job) (process_memory_usage)",
          "legendFormat": "{{exported_job}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      }
    },
    {
      "id": 17,
      "type": "timeseries",
      "title": "Open file descriptors",
      "description": "Shows open file descriptor count per agents process; approaching the OS ulimit risks the process failing to open new sockets or files.",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 16,
        "y": 28
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (exported_job) (process_open_file_descriptor_count)",
          "legendFormat": "{{exported_job}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 35
      },
      "id": 18,
