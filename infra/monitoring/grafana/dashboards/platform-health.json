        },
        "showPercentChange": false,
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "(sum(rate(otelcol_receiver_refused_spans[$__rate_interval])) or vector(0)) + (sum(rate(otelcol_receiver_refused_metric_points[$__rate_interval])) or vector(0)) + (sum(rate(otelcol_receiver_refused_log_records[$__rate_interval])) or vector(0)) + (sum(rate(otelcol_receiver_failed_spans[$__rate_interval])) or vector(0)) + (sum(rate(otelcol_receiver_failed_metric_points[$__rate_interval])) or vector(0)) + (sum(rate(otelcol_receiver_failed_log_records[$__rate_interval])) or vector(0)) + (sum(rate(otelcol_exporter_send_failed_spans[$__rate_interval])) or vector(0)) + (sum(rate(otelcol_exporter_send_failed_metric_points[$__rate_interval])) or vector(0)) + (sum(rate(otelcol_exporter_send_failed_log_records[$__rate_interval])) or vector(0)) + (sum(rate(otelcol_exporter_enqueue_failed_spans[$__rate_interval])) or vector(0)) + (sum(rate(otelcol_exporter_enqueue_failed_metric_points[$__rate_interval])) or vector(0)) + (sum(rate(otelcol_exporter_enqueue_failed_log_records[$__rate_interval])) or vector(0))",
          "instant": true,
          "legendFormat": "items/s",
          "range": false,
          "refId": "A"
        }
      ],
