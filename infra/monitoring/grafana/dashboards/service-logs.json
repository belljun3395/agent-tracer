{
  "uid": "service-logs",
  "title": "Service Logs",
  "tags": [
    "agent-tracer",
    "logs"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "allValue": ".+",
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "definition": "label_values(service_name)",
        "hide": 0,
        "includeAll": true,
        "label": "Service",
        "multi": true,
        "name": "service_name",
        "options": [],
        "query": "label_values(service_name)",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      },
      {
        "allValue": ".*",
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "hide": 0,
        "includeAll": true,
        "label": "Detected level",
        "multi": true,
        "name": "detected_level",
        "options": [],
        "query": "trace,debug,info,warn,error,critical,fatal,unknown",
        "skipUrlSync": false,
        "type": "custom"
      },
      {
        "current": {
          "selected": true,
          "text": ".*",
          "value": ".*"
        },
        "hide": 0,
        "label": "Event name (regex)",
        "name": "msg",
        "options": [
          {
            "selected": true,
            "text": ".*",
            "value": ".*"
          }
        ],
        "query": ".*",
        "skipUrlSync": false,
        "type": "textbox"
      },
      {
        "current": {
          "selected": true,
          "text": "",
          "value": ""
        },
        "hide": 0,
        "label": "Contains text",
        "name": "search",
        "options": [
          {
            "selected": true,
            "text": "",
            "value": ""
          }
        ],
        "query": "",
        "skipUrlSync": false,
        "type": "textbox"
      },
      {
        "current": {
          "selected": true,
          "text": "1000",
          "value": "1000"
        },
        "hide": 0,
        "label": "Slow threshold (ms)",
        "name": "slow_ms",
        "options": [
          {
            "selected": true,
            "text": "1000",
            "value": "1000"
          }
        ],
        "query": "1000",
        "skipUrlSync": false,
        "type": "textbox"
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "What is happening",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1
    },
    {
      "id": 2,
      "title": "Recent logs",
      "description": "선택한 서비스의 원문이다. JSON으로 파싱하지 않으므로 크래시 스택 같은 평문 줄도 그대로 보인다. 줄을 펼치면 trace_id로 Tempo 트레이스까지 건너뛴다.",
      "type": "logs",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "editorMode": "code",
          "queryType": "range",
          "expr": "{service_name=~\"$service_name\", detected_level=~\"$detected_level\"} |~ \"$msg\" |= \"$search\""
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 1
      }
    },
    {
      "type": "row",
      "title": "Event volume",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 13
      },
      "id": 3
    },
    {
      "id": 4,
      "title": "Events by name",
      "type": "bargauge",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "description": "msg 값별 발생 수다. 평소 분포에서 벗어난 이벤트가 조사 시작점이다.",
      "targets": [
        {
          "refId": "A",
          "editorMode": "code",
          "instant": true,
          "expr": "topk(15, sum by (msg) (count_over_time({service_name=~\"$service_name\", detected_level=~\"$detected_level\"} | json | __error__=\"\" | msg=~\"$msg\" |= \"$search\" [$__range])))",
          "legendFormat": "{{msg}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "continuous-BlPu"
          }
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "showUnfilled": true,
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "legend": {
          "showLegend": false
        }
      },
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 14
      }
    },
    {
      "id": 5,
      "title": "Log intake by level",
      "description": "수준별 초당 로그 수다. warn·error가 평소보다 솟으면 그 구간을 최근 로그에서 본다.",
      "type": "timeseries",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "editorMode": "code",
          "expr": "sum by (detected_level) (rate({service_name=~\"$service_name\", detected_level=~\"$detected_level\"} |= \"$search\" [$__auto]))",
          "legendFormat": "{{detected_level}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "logs/s",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true,
          "calcs": [
            "mean",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 12,
        "y": 14
      }
    },
    {
      "type": "row",
      "title": "Failures",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 24
      },
      "id": 6
    },
    {
      "id": 7,
      "title": "Failure events over time",
      "description": "error 수준 로그를 msg별로 나눈 것이다. 어떤 실패가 늘고 있는지 이름으로 바로 드러난다.",
      "type": "timeseries",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "editorMode": "code",
          "expr": "sum by (msg) (rate({service_name=~\"$service_name\", detected_level=~\"error|critical|fatal\"} | json | __error__=\"\" [$__auto]))",
          "legendFormat": "{{msg}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "logs/s",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true,
          "calcs": [
            "mean",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 25
      }
    },
    {
      "id": 8,
      "title": "Failure log bodies",
      "description": "error 수준 원문이다. 대개 error 필드에 원인이, 상관 식별자에 대상이 들어 있다.",
      "type": "logs",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "editorMode": "code",
          "queryType": "range",
          "expr": "{service_name=~\"$service_name\", detected_level=~\"error|critical|fatal\"} |~ \"$msg\" |= \"$search\""
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 35
      }
    },
    {
      "type": "row",
      "title": "Slow work",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 47
      },
      "id": 9
    },
    {
      "id": 10,
      "title": "durationMs p95",
      "description": "durationMs를 싣는 모든 로그의 95분위다. HTTP 요청과 배치 적용이 함께 보인다.",
      "type": "timeseries",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "editorMode": "code",
          "expr": "quantile_over_time(0.95, {service_name=~\"$service_name\", detected_level=~\"$detected_level\"} | json | __error__=\"\" | msg=~\"$msg\" | unwrap durationMs [$__auto]) by (service_name, msg)",
          "legendFormat": "{{service_name}} {{msg}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true,
          "calcs": [
            "mean",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 48
      }
    },
    {
      "id": 11,
      "title": "Slow log bodies",
      "description": "durationMs가 임계값을 넘은 줄만 남긴다. 임계값은 slow_ms 변수로 바꾼다.",
      "type": "logs",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "editorMode": "code",
          "queryType": "range",
          "expr": "{service_name=~\"$service_name\", detected_level=~\"$detected_level\"} | json | __error__=\"\" | msg=~\"$msg\" | durationMs > $slow_ms"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 12,
        "y": 48
      }
    }
  ]
}
