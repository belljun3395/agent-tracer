FROM node:22-alpine AS builder

WORKDIR /app
COPY package*.json ./
COPY packages/server/package.json packages/server/
COPY packages/adapter-mcp/package.json packages/adapter-mcp/
COPY packages/web-app/package.json packages/web-app/
RUN apk add --no-cache python3 make g++
RUN npm ci

COPY . .
RUN npm run build --workspace=@monitor/web-app
RUN DOCS_BASE=/docs/ DOCS_LAST_UPDATED=false npm run docs:build

FROM nginx:alpine
COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/packages/web-app/dist /usr/share/nginx/html
COPY --from=builder /app/docs/.vitepress/dist /usr/share/nginx/docs
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
