{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "websearch": "allow",
    "webfetch": "allow",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "external_directory": "ask",
    "doom_loop": "ask"
  },
  "mcp": {
    "monitor": {
      "type": "local",
      "command": ["node", "packages/mcp/dist/index.js"],
      "enabled": true,
      "environment": {
        "MONITOR_BASE_URL": "http://127.0.0.1:3847"
      }
    }
  }
}
