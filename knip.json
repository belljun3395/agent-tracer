{
  "workspaces": {
    "packages/server": {},
    "packages/web": {},
    "packages/runtime": {
      "entry": [
        "src/claude-code/hooks/**/*.ts",
        "src/codex/hooks/**/*.ts"
      ]
    }
  },
  "exclude": ["types", "unresolved"],
  "ignoreExportsUsedInFile": true,
  "ignore": [
    "docs/**",
    "scripts/register-swc.mjs",
    "scripts/seed-preview.mjs",
    "scripts/record-preview-demo.mjs",
    "scripts/snapshot-preview.mjs",
    "packages/server/src/activity/event/domain/event.phase.ts",
    "packages/server/src/activity/event/domain/model/event.phase.model.ts",
    "packages/server/src/activity/event/domain/runtime/type/metadata.keys.type.ts",
    "packages/server/src/activity/event/domain/type/event.metadata.type.ts",
    "packages/server/src/activity/event/repository/event-store/event.time.ts",
    "packages/server/src/adapters/http/shared/schemas/query.schema.ts",
    "packages/server/src/governance/verification/application/outbound/tokens.ts",
    "packages/server/src/governance/verification/domain/type/turn.evaluation.type.ts",
    "packages/web/src/io/storage.ts",
    "packages/web/src/domain/snapshot.ts"
  ],
  "ignoreDependencies": [
    "zod",
    "rxjs",
    "yaml",
    "eslint-plugin-n",
    "mermaid",
    "tsx",
    "@swc-node/register",
    "@vitest/coverage-v8",
    "@types/supertest",
    "supertest"
  ]
}
