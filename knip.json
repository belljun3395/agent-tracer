{
  "workspaces": {
    "packages/server/api-gateway": {
      "ignoreDependencies": ["ws"]
    },
    "packages/web": {},
    "packages/runtime": {
      "entry": [
        "src/claude-code/hooks/**/*.ts",
        "src/codex/hooks/**/*.ts"
      ]
    }
  },
  "exclude": ["types", "unresolved"],
  "ignoreExportsUsedInFile": true,
  "ignore": [
    "docs/**",
    "scripts/register-swc.mjs",
    "scripts/seed-preview.mjs",
    "scripts/record-preview-demo.mjs",
    "scripts/snapshot-preview.mjs",
    "packages/runtime/build.ts",
    "packages/web/src/io/storage.ts",
    "packages/web/src/domain/snapshot.ts"
  ],
  "ignoreDependencies": [
    "zod",
    "rxjs",
    "yaml",
    "eslint-plugin-n",
    "mermaid",
    "tsx",
    "@swc-node/register",
    "@vitest/coverage-v8",
    "@types/supertest",
    "supertest"
  ]
}
