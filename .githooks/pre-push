#!/bin/sh
# commit-msg를 건너뛴 커밋이 origin에 닿기 전 마지막으로 막는다.
# 다른 도구가 --no-verify로 커밋하면 CI가 사후에 잡는 것 말고는 걸리는 자리가 없다.
ROOT="$(git rev-parse --show-toplevel)"
ZERO="0000000000000000000000000000000000000000"
failed=0

while read -r _local_ref local_sha _remote_ref remote_sha; do
  [ "$local_sha" = "$ZERO" ] && continue

  # 새 브랜치는 원격에 비교 대상이 없으므로 이미 올라간 커밋을 빼고 본다.
  if [ "$remote_sha" = "$ZERO" ]; then
    shas=$(git log "$local_sha" --not --remotes --format=%H)
  else
    shas=$(git log "$remote_sha..$local_sha" --format=%H)
  fi

  for sha in $shas; do
    msg=$(git rev-parse --git-dir)/PRE_PUSH_MSG
    git log -1 --format=%B "$sha" > "$msg"
    if ! node "$ROOT/scripts/check-commit-msg.mjs" "$msg"; then
      echo "  ↳ $(git log -1 --format='%h %s' "$sha")"
      failed=1
    fi
    if ! node "$ROOT/scripts/check-coauthors.mjs" --file "$msg"; then
      echo "  ↳ $(git log -1 --format='%h %s' "$sha")"
      failed=1
    fi
    rm -f "$msg"
  done
done

exit $failed
