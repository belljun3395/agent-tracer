{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@monitor/shared-kernel/*": [
        "packages/shared-kernel/src/*"
      ],
      "@monitor/contracts/*": [
        "packages/contracts/src/*"
      ],
      "@monitor/activity/*": [
        "packages/activity/src/*"
      ],
      "@monitor/work/*": [
        "packages/work/src/*"
      ],
      "~governance/*": [
        "packages/server/src/governance/*"
      ],
      "~config/*": [
        "packages/server/src/config/*"
      ],
      "~adapters/*": [
        "packages/server/src/adapters/*"
      ],
      "~main/*": [
        "packages/server/src/main/*"
      ],
      "~identity/*": [
        "packages/server/src/identity/*"
      ],
      "@monitor/server": [
        "packages/server/src/server.entry.ts"
      ],
      "@monitor/web": [
        "packages/web/src/main.tsx"
      ],
      "@monitor/runtime/*": [
        "packages/runtime/src/*"
      ]
    },
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "exactOptionalPropertyTypes": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  }
}
