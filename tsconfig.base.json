{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@monitor/shared/*": [
        "packages/server/shared/src/*"
      ],
      "@monitor/timeline-api/*": [
        "packages/server/timeline-api/src/*"
      ],
      "@monitor/run-api/*": [
        "packages/server/run-api/src/*"
      ],
      "@monitor/rules-api/*": [
        "packages/server/rules-api/src/*"
      ],
      "@monitor/insight-api/*": [
        "packages/server/insight-api/src/*"
      ],
      "~config/*": [
        "packages/server/api-gateway/src/config/*"
      ],
      "@monitor/identity-api/*": [
        "packages/server/identity-api/src/*"
      ],
      "@monitor/ws-gateway/*": [
        "packages/server/ws-gateway/src/*"
      ],
      "~adapters/*": [
        "packages/server/api-gateway/src/adapters/*"
      ],
      "~main/*": [
        "packages/server/api-gateway/src/main/*"
      ],
      "@monitor/api-gateway": [
        "packages/server/api-gateway/src/gateway.entry.ts"
      ],
      "@monitor/server-core/*": [
        "packages/server/server-core/src/*"
      ],
      "@monitor/web": [
        "packages/web/src/main.tsx"
      ],
      "@monitor/runtime/*": [
        "packages/runtime/src/*"
      ]
    },
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "exactOptionalPropertyTypes": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  }
}
